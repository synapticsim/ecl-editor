{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "files": {
        "includes": ["src/**", "*.json", "*.ts"]
    },
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": {
                    "level": "on",
                    "options": {
                        "groups": [":NODE:", ":PACKAGE:", ":BLANK_LINE:", ":PATH:", ":BLANK_LINE:", ":ALIAS:"]
                    }
                }
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "a11y": "off",
            "complexity": {
                "noUselessSwitchCase": "off"
            },
            "correctness": {
                "noUnusedImports": "error"
            },
            "style": {
                "noNonNullAssertion": "off"
            },
            "suspicious": {
                "noConstEnum": "off",
                "noPrototypeBuiltins": "off"
            }
        }
    }
}
